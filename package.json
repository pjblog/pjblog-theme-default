{
  "name": "pjblog-theme-default",
  "version": "1.0.17",
  "description": "pjblog default theme",
  "main": "index.js",
  "files": [
    "dist/ssr",
    "index.js"
  ],
  "scripts": {
    "dev": "npm run dev:ssr",
    "dev:ssr": "SSR=true vite --host",
    "build": "rm -rf dist && npm run build:ssr",
    "build:client": "KIND=client vite build",
    "build:server": "KIND=server vite build",
    "build:ssr": "npm run build:client && npm run build:server",
    "pub": "npm run build && git add . && git commit -am 'update' && git push && npm publish"
  },
  "dependencies": {
    "@codixjs/codix": "^1.0.14",
    "@codixjs/fetch": "^1.0.0",
    "@codixjs/server": "^1.0.0",
    "antd": "^4.24.1",
    "axios": "^1.1.3",
    "dayjs": "^1.11.6",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "serve-static": "^1.15.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.18.6",
    "@codixjs/vite": "^1.0.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^1.3.0",
    "less": "^4.1.3",
    "typescript": "^4.8.4",
    "vite": "^3.1.8"
  },
  "config": {
    "entries": {
      "spa": "./src/entries/spa.tsx",
      "client": "./src/entries/client.tsx",
      "server": "./src/entries/server.tsx"
    },
    "skips": [
      "/demo//@react-refresh",
      "/demo/@id/vite/modulepreload-polyfill",
      "/demo/@vite/client"
    ],
    "rewrites": {
      "/index.html": "/"
    }
  },
  "manifest": {},
  "pjblog": {
    "type": "theme",
    "icon": "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQ3SflsXv3RLuu6lANX9MkJP2Ohb3jeLbqXUQ&usqp=CAU",
    "plugins": {},
    "previews": [
      "https://react-photo-view.vercel.app/_next/static/media/1.c788857d.jpg",
      "https://react-photo-view.vercel.app/_next/static/media/2.b43f1ead.jpg",
      "https://react-photo-view.vercel.app/_next/static/media/3.70695fb9.jpg",
      "https://react-photo-view.vercel.app/_next/static/media/4.57ff8e86.jpg",
      "https://react-photo-view.vercel.app/_next/static/media/5.7ace37c7.jpg",
      "https://react-photo-view.vercel.app/_next/static/media/6.0271162c.jpg"
    ]
  }
}
